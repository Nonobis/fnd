{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FND",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "args": [
                "-config",
                "config.json"
            ],
            "env": {
                "PORT": "8080"
            },
            "console": "integratedTerminal",
            "showLog": true,
            "trace": "verbose",
            "logOutput": "rpc"
        },
        {
            "name": "Debug FND (Development)",
            "type": "go", 
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "args": [
                "-config",
                "config.json",
                "-debug"
            ],
            "env": {
                "PORT": "8080",
                "DEBUG": "true"
            },
            "console": "integratedTerminal",
            "showLog": true,
            "trace": "verbose",
            "logOutput": "rpc"
        },
        {
            "name": "Run FND (No Debug)",
            "type": "go",
            "request": "launch", 
            "mode": "exec",
            "program": "${workspaceFolder}",
            "args": [
                "-config",
                "config.json"
            ],
            "env": {
                "PORT": "8080"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Debug FND Tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}",
            "env": {},
            "args": [
                "-test.v"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Current File",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}

