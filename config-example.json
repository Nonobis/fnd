{
  "Frigate": {
    "Host": "frigate",
    "Port": "5000",
    "MqttServer": "mqtt-server",
    "MqttPort": "1883",
    "Cooldown": 60,
    "Cameras": {
      "camera1": {
        "name": "camera1",
        "active": true,
        "objectFilter": {
          "enabled": false,
          "objects": []
        }
      },
      "camera2": {
        "name": "camera2",
        "active": true,
        "objectFilter": {
          "enabled": true,
          "objects": ["person", "car"]
        }
      }
    },
    "Language": "en",
    "VideoEnabled": true,
    "VideoUrlOnly": false,
    "MaxVideoSizeMB": 10,
    "ExternalURL": "https://votre-domaine.com/frigate"
  },
  "Notify": {
    "Conf": {
      "Web": {
        "Map": {
          "enabled": "true"
        }
      },
      "Telegram": {
        "Map": {
          "enabled": "false",
          "token": "",
          "chatid": ""
        }
      },
      "Gotify": {
        "Map": {
          "enabled": "false",
          "serverurl": "http://gotify:80",
          "apptoken": "",
          "priority": "5"
        }
      }
    },
    "apprise": {
      "enabled": false,
      "configID": "",
      "serverURL": "http://apprise:8000",
      "timeout": 30,
      "format": "text"
    }
  },
  "FacialRecognition": {
    "enabled": false,
    "codeProjectAIHost": "localhost",
    "codeProjectAIPort": 8000,
    "codeProjectAIUseSSL": false,
    "codeProjectAITimeout": 30,
    "faceDetectionEnabled": true,
    "faceRecognitionEnabled": true,
    "faceDatabasePath": "./face_db"
  }
}
