{
  "Frigate": {
    "Host": "frigate",
    "Port": "5000",
    "MqttServer": "mqtt-server",
    "MqttPort": "1883",
    "Cooldown": 60,
    "Cameras": {},
    "Language": "en",
    "VideoEnabled": true,
    "VideoUrlOnly": false,
    "MaxVideoSizeMB": 10,
    "ExternalURL": "https://votre-domaine.com/frigate"
  },
  "Notify": {
    "Conf": {
      "Web": {
        "Map": {
          "enabled": "true"
        }
      },
      "Telegram": {
        "Map": {
          "enabled": "false",
          "token": "",
          "chatid": ""
        }
      },
      "Gotify": {
        "Map": {
          "enabled": "false",
          "serverurl": "http://gotify:80",
          "apptoken": "",
          "priority": "5"
        }
      }
    },
    "apprise": {
      "enabled": false,
      "configID": "",
      "serverURL": "http://apprise:8000",
      "timeout": 30,
      "format": "text"
    }
  }
}
